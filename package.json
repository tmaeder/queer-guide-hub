{
  "name": "queer-guide",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/check-env.mjs",
    "check:env": "node scripts/check-env.mjs",
    "prebuild": "tsx scripts/sync-public-locales.ts --write && tsc --noEmit",
    "build": "vite build",
    "build:check": "tsx scripts/sync-public-locales.ts --write && tsc --noEmit && node --max-old-space-size=8192 node_modules/vite/bin/vite.js build && node scripts/check-bundle-shape.mjs",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "preview": "vite preview",
    "prerender": "node scripts/prerender.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "bones": "boneyard build",
    "bones:force": "boneyard build --force",
    "gates": "node scripts/check-data-quality-gates.mjs",
    "i18n:check": "tsx scripts/sync-translations.ts && tsx scripts/sync-public-locales.ts --check",
    "i18n:check:defaults": "node scripts/check-i18n-german-defaults.mjs",
    "i18n:fill": "tsx scripts/sync-translations.ts --fill",
    "i18n:sync": "tsx scripts/sync-public-locales.ts --write",
    "verify:gh-sync": "tsx scripts/verify-github-sync.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@bigheads/core": "^0.3.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
