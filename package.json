{
  "name": "queer-guide",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js build && node scripts/check-bundle-shape.mjs",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "preview": "vite preview",
    "prerender": "node scripts/prerender.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "bones": "boneyard build",
    "bones:force": "boneyard build --force",
    "i18n:check": "tsx scripts/sync-translations.ts",
    "i18n:check:defaults": "node scripts/check-i18n-german-defaults.mjs",
    "i18n:fill": "tsx scripts/sync-translations.ts --fill",
    "verify:gh-sync": "tsx scripts/verify-github-sync.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
