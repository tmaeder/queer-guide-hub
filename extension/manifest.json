{
  "manifest_version": 3,
  "name": "queer.guide capture",
  "version": "0.9.0",
  "description": "Capture venues, events, hotels, marketplace items, and news from any webpage and submit them to queer.guide.",
  "action": {
    "default_title": "queer.guide capture",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [],
  "externally_connectable": {
    "matches": [
      "https://queer.guide/*",
      "https://www.queer.guide/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://queer.guide/*",
        "https://www.queer.guide/*"
      ],
      "js": [
        "src/content/qg-bridge.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "qg-submit-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Submit the current selection to queer.guide"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
