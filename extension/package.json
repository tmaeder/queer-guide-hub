{
  "name": "queer-guide-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that captures venues, events, hotels, marketplace items and news from the open web and submits them to queer.guide for moderation.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "rollup": "2.80.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.10.6",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
