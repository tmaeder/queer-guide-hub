{
  "name": "queer-guide-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that captures venues, events, hotels, marketplace items and news from the open web and submits them to queer.guide for moderation.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "rollup": "2.80.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.9.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
