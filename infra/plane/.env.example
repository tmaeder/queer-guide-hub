# Plane self-host — plane.queer.guide
# Copy to `.env` on the VM and fill in secrets. NEVER commit the filled .env.
# chmod 600 .env && chown plane:plane .env

# ── Image tag ────────────────────────────────────────────────────────────────
# Pin to a specific Plane release. Check https://github.com/makeplane/plane/releases
# before bumping. After bump: ./backup/backup.sh && docker compose pull && docker compose up -d
PLANE_VERSION=stable

# ── Public URL ───────────────────────────────────────────────────────────────
WEB_URL=https://plane.queer.guide
CORS_ALLOWED_ORIGINS=https://plane.queer.guide
APP_DOMAIN=plane.queer.guide
LIVE_URL=https://plane.queer.guide/live

# ── Django / API ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=REPLACE_ME
DEBUG=0
# Signups restricted: admins are invited by email and authenticate via magic-link.
# No OAuth providers — email magic-link only, delivered via Resend SMTP.
ENABLE_SIGNUP=0
ENABLE_EMAIL_PASSWORD=0
ENABLE_MAGIC_LINK_LOGIN=1

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=plane
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=plane
POSTGRES_HOST=plane-db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://plane:REPLACE_ME@plane-db:5432/plane
PGHOST=plane-db
PGUSER=plane
PGPASSWORD=REPLACE_ME
PGDATABASE=plane

# ── Redis / Valkey ───────────────────────────────────────────────────────────
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=REPLACE_ME
RABBITMQ_DEFAULT_VHOST=plane
AMQP_URL=amqp://plane:REPLACE_ME@plane-mq:5672/plane

# ── Object storage: Cloudflare R2 (S3-compatible) ────────────────────────────
# Create bucket `qg-plane-assets` in Cloudflare dashboard. Generate R2 API token
# scoped to that bucket (Object Read & Write). Endpoint format:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
USE_MINIO=0
AWS_REGION=auto
AWS_S3_ENDPOINT_URL=https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_S3_BUCKET_NAME=qg-plane-assets
AWS_S3_ADDRESSING_STYLE=virtual
AWS_S3_SIGNATURE_VERSION=s3v4
FILE_SIZE_LIMIT=5242880

# ── Auth: magic-link only ────────────────────────────────────────────────────
# No OAuth. Admins are invited by email; Plane emails a one-time sign-in link
# via Resend SMTP (configured below). Leave OAuth env vars empty.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── SMTP (transactional email) — Resend ──────────────────────────────────────
# Resend SMTP relay. Generate API key at https://resend.com/api-keys.
# Verify `queer.guide` domain at https://resend.com/domains before use.
EMAIL_HOST=smtp.resend.com
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=REPLACE_WITH_RESEND_API_KEY
EMAIL_PORT=465
EMAIL_USE_TLS=0
EMAIL_USE_SSL=1
EMAIL_FROM=plane@queer.guide
DEFAULT_FROM_EMAIL=plane@queer.guide

# ── Plane internal proxy (nginx) ─────────────────────────────────────────────
# Served only on the `web` docker network; Caddy reverse-proxies to plane-proxy:80.
NGINX_PORT=80

# ── Backups (used by backup/backup.sh, not by containers) ────────────────────
BACKUP_R2_BUCKET=qg-plane-backups
BACKUP_R2_ENDPOINT=https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
BACKUP_R2_ACCESS_KEY_ID=REPLACE_ME
BACKUP_R2_SECRET_ACCESS_KEY=REPLACE_ME
BACKUP_RETENTION_DAYS=30
