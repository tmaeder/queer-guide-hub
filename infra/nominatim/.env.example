## Nominatim self-host on the queer.guide VPS.
## Copy to .env on the VPS and fill in values.

# Random 32+ char password for the embedded Postgres. Generate with:
#   openssl rand -hex 32
NOMINATIM_DB_PASSWORD=REPLACE_ME

# Edge-function shared secret for IP-allowlist bypass on dev/local
# (Caddy basic-auth; see Caddyfile snippet in README §2.3). Optional.
NOMINATIM_BASIC_AUTH_USER=qg
NOMINATIM_BASIC_AUTH_HASH=REPLACE_ME_BCRYPT  # caddy hash-password
