[Unit]
Description=Apply OSM diff to Nominatim
After=nominatim.service
Requires=nominatim.service

[Service]
Type=oneshot
User=plane
Group=plane
WorkingDirectory=/opt/plane/QG/infra/nominatim
# Mediagis image ships nominatim-update in /app/init.sh modes.
ExecStart=/usr/bin/docker exec nominatim sudo -u nominatim nominatim replication --once
