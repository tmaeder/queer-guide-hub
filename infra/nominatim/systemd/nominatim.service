[Unit]
Description=Self-hosted Nominatim reverse-geocoder
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
User=plane
Group=plane
WorkingDirectory=/opt/plane/QG/infra/nominatim
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
