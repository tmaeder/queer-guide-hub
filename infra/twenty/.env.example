# Twenty self-host secrets — copy to .env (gitignored) and fill in.
# NOTE: the working local install uses Twenty's OFFICIAL upstream compose + .env
# (see docs/integrations/twenty-crm-sync.md go-live step 1). This file mirrors the
# vars that matter. Current Twenty uses ENCRYPTION_KEY (not the legacy APP_SECRET).
TAG=latest
SERVER_URL=http://localhost:3000   # set to https://crm.queer.guide behind a proxy
STORAGE_TYPE=local
# openssl rand -base64 32
ENCRYPTION_KEY=change-me-strong
# Postgres defaults to postgres/postgres@db in the upstream compose; override if desired
# PG_DATABASE_PASSWORD=change-me-strong
