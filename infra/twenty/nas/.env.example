# Twenty-on-NAS secrets — copy to .env (gitignored) and fill in.
TAG=latest
SERVER_URL=https://crm.queer.guide

# openssl rand -base64 32   (do NOT change once data exists — it encrypts fields)
ENCRYPTION_KEY=

# Postgres (internal to the compose network)
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=

# Cloudflare Tunnel token — from Zero Trust → Networks → Tunnels → your tunnel → Install connector
TUNNEL_TOKEN=

# --- Team-inbox mail (Stalwart + Resend) ---
# Stalwart first-boot fallback admin password (openssl rand -base64 24). Rotate
# after logging into the web-admin.
STALWART_ADMIN_SECRET=
# Resend API key — reuse the platform's existing key (same one Supabase uses).
# Powers both Twenty's system email and Stalwart's outbound smarthost relay.
RESEND_API_KEY=
# Optional overrides (sensible defaults live in docker-compose.yml):
# IS_IMAP_SMTP_CALDAV_ENABLED=true
# OUTBOUND_HTTP_SAFE_MODE_ENABLED=false   # required: lets Twenty reach Stalwart on the private net
# EMAIL_DRIVER=SMTP
# EMAIL_SMTP_HOST=smtp.resend.com
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_USER=resend
# EMAIL_FROM_ADDRESS=noreply@queer.guide
# EMAIL_FROM_NAME=Queer Guide
#
# NOTE: the per-mailbox account passwords (contact@/support@/legal@/press@) are
# created in the Stalwart web-admin. Put the same values in the team-inbox
# Cloudflare Worker secret STALWART_MAILBOX_PASSWORDS and in Twenty's per-account
# IMAP/SMTP settings — they are not stored in this file.

# --- Optional: use queer.guide's existing Cloudflare R2 for file storage ---
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=auto
# STORAGE_S3_NAME=twenty-storage
# STORAGE_S3_ENDPOINT=https://7aa3765cc5f50f2b681b782eb4a8d296.r2.cloudflarestorage.com
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
