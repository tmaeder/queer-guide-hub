## ntfy self-host on the queer.guide VPS.
## Copy to .env on the VPS and fill in values. Not read by docker-compose.yml
## directly (server.yml has no ${VAR} substitution) — this is a record of
## generated secrets for the README setup steps + 1Password, not a runtime
## env file.

# HTTP basic-auth fallback for ad-hoc curl against /v1/account* from a
# laptop, bypassing the Supabase-egress IP allowlist (see Caddyfile
# snippet). Optional — only needed for manual debugging.
NTFY_ADMIN_BASIC_AUTH_USER=qg
NTFY_ADMIN_BASIC_AUTH_HASH=REPLACE_ME_BCRYPT  # caddy hash-password

# Generated once during bootstrap (README §2.5) for the qg-publisher
# account that the ntfy-dispatcher edge function uses to publish to
# every user's topic. Store the cleartext in 1Password
# (queer.guide / ntfy / qg-publisher) and set NTFY_PUBLISHER_TOKEN as a
# Supabase edge function secret — never commit it here.
# QG_PUBLISHER_TOKEN=REPLACE_ME
