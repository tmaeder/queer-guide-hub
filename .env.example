# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Search
VITE_SEARCH_PROXY_URL=https://your-search-proxy.workers.dev
VITE_API_URL=https://your-project.supabase.co/functions/v1

# Maps
VITE_BASEMAP_ASSETS_URL=https://your-basemap-assets.example.com

# Cloudflare Turnstile (CAPTCHA on auth forms).
# PUBLIC site key — must match the secret key configured in the Supabase
# dashboard (Authentication → Bot & Abuse Protection → Cloudflare Turnstile).
# Required in production because Supabase Auth rejects sign-in / sign-up /
# password-reset requests without a captcha token. Leave empty to disable the
# widget locally (only works if CAPTCHA is also disabled in Supabase).
VITE_TURNSTILE_SITE_KEY=

# Sentry (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=

# Web Push (optional)
VITE_VAPID_PUBLIC=

# Feature flags (optional)
VITE_LEGACY_NEWS_TRIGGER=false
VITE_TRIP_CONTEXT_BAR=false

# Scraper secret (optional, admin only)
VITE_SCRAPER_SECRET=
