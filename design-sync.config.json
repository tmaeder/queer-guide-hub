{
  "pkg": "queer-guide",
  "globalName": "QueerGuideDS",
  "shape": "package",
  "tsconfig": "tsconfig.json",
  "srcDir": "src/components/ui",
  "buildCmd": "npx @tailwindcss/cli@4 -i .design-sync/tailwind-entry.css -o .design-sync/.cache/tailwind-ds.css --minify=false && npx tsc -p tsconfig.app.json --emitDeclarationOnly --declaration --noEmit false --noCheck --declarationDir types; node .design-sync/gen-types-entry.mjs",
  "cssEntry": ".design-sync/.cache/tailwind-ds.css",
  "extraFonts": [".design-sync/fonts-inter.css"],
  "entry": "./dist/index.es.js",
  "guidelinesGlob": [".design-sync/design-guidelines.md"],
  "componentSrcMap": {
    "Accordion": "src/components/ui/accordion.tsx",
    "Alert": "src/components/ui/alert.tsx",
    "AlertDialog": "src/components/ui/alert-dialog.tsx",
    "AnimatedBeamConnector": "src/components/ui/AnimatedBeamConnector.tsx",
    "Avatar": "src/components/ui/avatar.tsx",
    "Badge": "src/components/ui/badge.tsx",
    "BentoGrid": "src/components/ui/bento-grid.tsx",
    "Button": "src/components/ui/button.tsx",
    "Calendar": "src/components/ui/calendar.tsx",
    "Card": "src/components/ui/card.tsx",
    "Checkbox": "src/components/ui/checkbox.tsx",
    "Collapsible": "src/components/ui/collapsible.tsx",
    "Command": "src/components/ui/command.tsx",
    "ContentWarningBanner": "src/components/ui/ContentWarningBanner.tsx",
    "CountryAutocomplete": "src/components/ui/country-autocomplete.tsx",
    "DatePickerWithRange": "src/components/ui/date-range-picker.tsx",
    "Dialog": "src/components/ui/dialog.tsx",
    "DropdownMenu": "src/components/ui/dropdown-menu.tsx",
    "EmptyState": "src/components/ui/EmptyState.tsx",
    "ErrorState": "src/components/ui/EmptyState.tsx",
    "Eyebrow": "src/components/ui/Eyebrow.tsx",
    "FavoriteButton": "src/components/ui/favorite-button.tsx",
    "FlatFieldGroup": "src/components/ui/FlatFieldGroup.tsx",
    "HoverCard": "src/components/ui/hover-card.tsx",
    "Image": "src/components/ui/Image.tsx",
    "ImageUpload": "src/components/ui/image-upload.tsx",
    "Input": "src/components/ui/input.tsx",
    "Label": "src/components/ui/label.tsx",
    "LegalPageLayout": "src/components/ui/LegalPageLayout.tsx",
    "Loading": "src/components/ui/loading.tsx",
    "LocationAutocomplete": "src/components/ui/location-autocomplete.tsx",
    "ModernAudioPlayer": "src/components/ui/modern-audio-player.tsx",
    "ModernVideoPlayer": "src/components/ui/modern-video-player.tsx",
    "MotionCard": "src/components/ui/MotionCard.tsx",
    "Pagination": "src/components/ui/pagination.tsx",
    "Popover": "src/components/ui/popover.tsx",
    "ProfessionAutocomplete": "src/components/ui/profession-autocomplete.tsx",
    "Progress": "src/components/ui/progress.tsx",
    "Rail": "src/components/ui/Rail.tsx",
    "ScrollArea": "src/components/ui/scroll-area.tsx",
    "Select": "src/components/ui/select.tsx",
    "Separator": "src/components/ui/separator.tsx",
    "Sheet": "src/components/ui/sheet.tsx",
    "Skeleton": "src/components/ui/skeleton.tsx",
    "Slider": "src/components/ui/slider.tsx",
    "StepperShell": "src/components/ui/StepperShell.tsx",
    "Switch": "src/components/ui/switch.tsx",
    "Table": "src/components/ui/table.tsx",
    "Tabs": "src/components/ui/tabs.tsx",
    "Textarea": "src/components/ui/textarea.tsx",
    "TierUpgradeOverlay": "src/components/ui/TierUpgradeOverlay.tsx",
    "Tooltip": "src/components/ui/tooltip.tsx",
    "VenueCombobox": "src/components/ui/venue-combobox.tsx"
  },
  "overrides": {
    "Dialog": { "cardMode": "single", "viewport": "800x620" },
    "AlertDialog": { "cardMode": "single", "viewport": "800x620" },
    "Sheet": { "cardMode": "single", "viewport": "900x620" },
    "Popover": { "cardMode": "single", "viewport": "600x460" },
    "HoverCard": { "cardMode": "single", "viewport": "600x460" },
    "Tooltip": { "cardMode": "single", "viewport": "500x300" },
    "DropdownMenu": { "cardMode": "single", "viewport": "600x520" },
    "Command": { "cardMode": "single", "viewport": "700x520" },
    "TierUpgradeOverlay": { "cardMode": "single", "viewport": "800x620" }
  },
  "docsMap": {
    "Alert": null,
    "Avatar": null,
    "Badge": null,
    "Button": null,
    "Calendar": null,
    "Card": null,
    "Checkbox": null,
    "Collapsible": null,
    "Command": null,
    "ContentWarningBanner": null,
    "Dialog": null,
    "EmptyState": null,
    "Input": null,
    "Label": null,
    "LegalPageLayout": null,
    "Loading": null,
    "Pagination": null,
    "Popover": null,
    "Progress": null,
    "Select": null,
    "Separator": null,
    "Sheet": null,
    "Skeleton": null,
    "Slider": null,
    "Switch": null,
    "Table": null,
    "Tabs": null,
    "Textarea": null,
    "Tooltip": null
  }
}
