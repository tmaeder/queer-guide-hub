# Redirect old /ressources to /resources
/ressources  /resources  301
/ressources/*  /resources/:splat  301

# Redirect old /tags to /resources
/tags  /resources  301
/tags/*  /resources/:splat  301

# P1.2 — /news/:slug → HTTP 410 Gone is served by functions/news/[slug].ts
# (CF Pages _redirects doesn't support 410). The news index page at /news
# survives as a curated headline list rendered by the SPA.

# P1.5 redirect removed 2026-05-24: /places revived as the editorial Atlas
# (cover destination + passport layer + editor rails). The SPA handles it.
# Sub-paths still redirect to /city for legacy compatibility — old /places/:slug
# style links pointed at city slugs.
/places/*  /city/:splat  301

# Asset paths get a real 404 when missing. Without these rules the SPA
# catch-all below returns index.html (200 text/html) for any unmatched
# /assets/* path — and stale browser sessions whose cached bundle still
# references an old chunk hash then try to import that HTML as JS and
# blow up with "Failed to load module script: text/html MIME". CF Pages
# tries the static file first; these rules only fire when no file exists.
# DO NOT add identity rewrites like `/sw.js /sw.js 200` here — they
# create infinite rewrite loops that abort CF rule parsing entirely
# (breaks the SPA catch-all below, every route returns 404).
/assets/*  /404.html  404
/icons/*   /404.html  404
/fonts/*   /404.html  404
/locales/*  /404.html  404

# Cloudflare Pages SPA catch-all (must be last)
/*    /index.html   200
